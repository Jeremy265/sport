generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model body_composition_categories {
  body_composition_category_id           Int                                      @id @default(autoincrement())
  title                                  String                                   @db.VarChar(45)
  unit_id                                Int
  user_id                                Int?
  created_at                             DateTime?                                @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime?                                @default(now()) @db.Timestamptz(6)
  units                                  units                                    @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
  users                                  users?                                   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  body_composition_category_visibilities body_composition_category_visibilities[]
  body_compositions                      body_compositions[]
}

model body_composition_category_visibilities {
  body_composition_category_id Int
  user_id                      Int
  visible                      Boolean?
  created_at                   DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime?                   @default(now()) @db.Timestamptz(6)
  body_composition_categories  body_composition_categories @relation(fields: [body_composition_category_id], references: [body_composition_category_id], onDelete: Cascade, map: "body_composition_category_vis_body_composition_category_id_fkey")
  users                        users                       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([body_composition_category_id, user_id])
}

model body_compositions {
  body_composition_id          Int                         @id @default(autoincrement())
  date                         DateTime?                   @default(now()) @db.Timestamptz(6)
  value                        Decimal                     @db.Decimal(5, 2)
  body_composition_category_id Int
  user_id                      Int
  created_at                   DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime?                   @default(now()) @db.Timestamptz(6)
  body_composition_categories  body_composition_categories @relation(fields: [body_composition_category_id], references: [body_composition_category_id], onDelete: Cascade)
  users                        users                       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model exercises {
  exercise_id Int       @id @default(autoincrement())
  title       String    @db.VarChar(45)
  image       String?   @db.VarChar(45)
  unit_id     Int
  user_id     Int?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  units       units     @relation(fields: [unit_id], references: [unit_id], onDelete: Cascade)
  users       users?    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  sets        sets[]
}

model sets {
  set_id      Int       @id @default(autoincrement())
  repetitions Int
  value       Decimal   @db.Decimal(4, 1)
  exercise_id Int
  training_id Int
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  exercises   exercises @relation(fields: [exercise_id], references: [exercise_id], onDelete: Cascade)
  trainings   trainings @relation(fields: [training_id], references: [training_id], onDelete: Cascade)
}

model trainings {
  training_id Int      @id @default(autoincrement())
  title       String?  @db.VarChar(45)
  date        DateTime @default(now()) @db.Timestamptz(6)
  user_id     Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  sets        sets[]
  users       users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model units {
  unit_id                     Int                           @id @default(autoincrement())
  title                       String                        @db.VarChar(45)
  user_id                     Int?
  is_user_managed             Boolean?                      @default(false)
  created_at                  DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime?                     @default(now()) @db.Timestamptz(6)
  body_composition_categories body_composition_categories[]
  exercises                   exercises[]
  users                       users?                        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model users {
  user_id                                Int                                      @id @default(autoincrement())
  first_name                             String                                   @db.VarChar(45)
  last_name                              String                                   @db.VarChar(45)
  email                                  String                                   @unique @db.VarChar(100)
  password                               String                                   @db.VarChar(100)
  created_at                             DateTime                                 @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime                                 @default(now()) @db.Timestamptz(6)
  body_composition_categories            body_composition_categories[]
  body_composition_category_visibilities body_composition_category_visibilities[]
  body_compositions                      body_compositions[]
  exercises                              exercises[]
  trainings                              trainings[]
  units                                  units[]
}
